{
  "name": "fashion-platform",
  "private": true,
  "workspaces": [
    "backend",
    "storefront",
    "admin"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:storefront": "npm run dev --workspace=storefront",
    "dev:admin": "npm run dev --workspace=admin",
    "dev": "concurrently -n backend,storefront,admin -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:storefront\" \"npm:dev:admin\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
