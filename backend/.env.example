# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database (MongoDB Atlas — live cluster, never mocked) ────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/luxeloom?retryWrites=true&w=majority

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-32-byte-base64-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Email OTP delivery. If INTEGRATIONS_MOCK=true, OTPs are logged to the
# server console instead of actually being emailed.
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="LuxeLoom <no-reply@luxeloom.example>"

# ─── Cloudinary (live — image storage/CDN, never mocked) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Global integrations mock switch ───────────────────────────────────────
# When true, Gemini / Razorpay / Snapmint / Blue Dart calls in lib/integrations/
# return realistic mock responses instead of hitting real APIs. Mongo and
# Cloudinary are always live regardless of this flag.
INTEGRATIONS_MOCK=true

# ─── Google Gemini (AI photo studio, stylist chat) ─────────────────────────
GEMINI_API_KEY=

# ─── Razorpay (online payments) ────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Snapmint (EMI) ─────────────────────────────────────────────────────────
SNAPMINT_MERCHANT_ID=
SNAPMINT_API_KEY=

# ─── Blue Dart / DHL India (shipping) ──────────────────────────────────────
BLUEDART_LICENSE_KEY=
BLUEDART_LOGIN_ID=
