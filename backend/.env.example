# --- Core (required for M1) ---
NODE_ENV=development
PORT=4000

# MongoDB Atlas connection string (Database > Connect > Drivers). Include the db name
# in the path, e.g. .../fashion?retryWrites=true&w=majority
MONGODB_URI=

# Any long random string (openssl rand -base64 48). Used to sign session JWTs.
JWT_SECRET=
JWT_EXPIRES_IN=7d

COOKIE_NAME=fp_session
# Leave blank in local dev (both frontends are on localhost, different ports only).
# In production, set to the shared parent domain, e.g. .yourdomain.com, so the
# session cookie is readable by both the storefront and admin subdomains.
COOKIE_DOMAIN=

# Comma-separated list of exact origins allowed to call this API with credentials.
# storefront runs on 3100, admin on 3101 (fixed ports, see storefront/admin package.json)
# so the two dev servers never fight over :3000 with anything else on the machine.
CORS_ORIGINS=http://localhost:3100,http://localhost:3101

# Used only by `npm run seed:admin` to provision the first admin account.
# Admin accounts are never created through the public signup endpoint.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Admin

# --- Milestone 2 (required from here on): Cloudinary (image storage + CDN delivery) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Milestone 2: Google Gemini (image *editing* — restages the uploaded photo as a
# clean catalog shot without changing the garment; not text-to-image generation) ---
GEMINI_API_KEY=
# Nano Banana Pro: highest fidelity, best for hero/primary shots, ~$0.13-0.24/image.
GEMINI_IMAGE_MODEL_PRIMARY=gemini-3-pro-image-preview
# Nano Banana 2: faster/cheaper, good for secondary angles or high-volume catalogs.
GEMINI_IMAGE_MODEL_FAST=gemini-3.1-flash-image

# --- Milestone 2: storefront cache invalidation on admin product writes (optional —
# silently skipped if unset). Must match storefront/.env.local's REVALIDATE_SECRET.
STOREFRONT_REVALIDATE_URL=http://localhost:3100/api/revalidate
REVALIDATE_SECRET=

# --- Milestone 5: Razorpay (payments; Snapmint EMI rides on the same checkout once
# enabled on your Razorpay account by Snapmint/Razorpay support — no separate keys
# needed for Snapmint). Use TEST mode keys from the Razorpay dashboard for dev.
# Optional: COD checkout works without these; the Razorpay routes 503 until set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Milestone 6: DHL shipping ---
# Ask which API variant applies to your shipping lanes before filling these in:
# MyDHL API (international express) vs DHL eCommerce (domestic parcel).
# DHL_API_KEY=
# DHL_API_SECRET=
# DHL_ACCOUNT_NUMBER=

# --- Milestone 7: Transactional email (order confirmation) ---
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_FROM="Fashion Store <orders@yourdomain.com>"
